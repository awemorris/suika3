{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Suika3",
      "type": "shell",
      "command": "suika3",
      "windows": {
        "command": "misc/windows/suika3-debug.exe"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Make Suika3 package",
      "type": "shell",
      "command": "suika3-pack",
      "args": [
        "`ls -A | grep -vE '^(misc|suika3.exe|.vscode)$'`"
      ],
      "windows": {
        "command": "powershell",
        "args": [
          "-Command",
          "& { $files = Get-ChildItem -Path . -Exclude 'misc', '.vscode', 'suika3.exe'; misc/windows/suika3-pack.exe @($files | ForEach-Object { $_.Name }) }"
        ]
      },
      "group": "build",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
