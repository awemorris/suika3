{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Suika3",
      "type": "shell",
      "command": "misc/windows/suika3-debug.exe",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Make Suika3 package",
      "type": "shell",
      "command": "misc/windows/suika3-pack.exe",
      "group": "build",
      "args": [
        "-Command",
        "& { $files = Get-ChildItem -Path . -Exclude 'misc', 'suika3.exe'; misc/windows/suika3-pack.exe @($files | ForEach-Object { $_.Name }) }"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
 ]
}
